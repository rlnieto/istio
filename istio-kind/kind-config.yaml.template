kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
nodes:
- role: control-plane
  extraPortMappings:
  # La variable de entorno está definida en el fichero 'environment'
  # que se carga en el script que usa esta configuración
  - containerPort: $INGRESS_NODEPORT
    hostPort: 9080
    protocol: TCP
